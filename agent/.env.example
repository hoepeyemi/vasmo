# Faktory Agent - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# RPC URL (use local Anvil for development, Cronos Testnet for hackathon)
CRONOS_RPC_URL=https://evm-t3.cronos.org

# Agent wallet private key (required for executing transactions)
# WARNING: Never commit real private keys to version control!
AGENT_PRIVATE_KEY=

# =============================================================================
# AI CONFIGURATION
# =============================================================================

# Anthropic API key (for AI explanations)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# WebSocket server port
WS_PORT=8080

# WebSocket authentication token (optional - leave empty for development)
# If set, clients must provide this token to connect
# WS_AUTH_TOKEN=your-secret-token-here

# =============================================================================
# CONTRACT ADDRESSES - CRONOS TESTNET (Chain ID: 338)
# =============================================================================

# Core contracts deployed to Cronos Testnet for x402 PayTech Hackathon
INVOICE_NFT_ADDRESS=0xEde6Db2855BACF191E5B2E2d91B6276bB56bf183
YIELD_VAULT_ADDRESS=0xD0db0eb608107862E963737FE87ffdFF7f400e3C
AGENT_ROUTER_ADDRESS=0xb8F4546e24e437779bC09c3b70ce70Ff9542bdD4
MOCK_ORACLE_ADDRESS=0x9A6d36A0487EA52df43E7704a97F47844C4Eac4E

# =============================================================================
# OPTIONAL: PRODUCTION DATA SOURCES
# =============================================================================

# Pyth Oracle address (for real-time price feeds)
# PYTH_ORACLE_ADDRESS=0x36825bf3Fbdf5a29E2d5148bfe7Dcf7B5639e320
